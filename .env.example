# Shared
NODE_ENV=development
PRODUCT_NAME=NOVA Connect

# API
PORT=4000
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:4000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
CALL_RECONNECT_GRACE_MS=12000
BCRYPT_ROUNDS=12
COOKIE_SECURE=false
# Use "lax" for the recommended same-origin deployment. Use "none" only when
# web and API are on different sites, and keep COOKIE_SECURE=true.
COOKIE_SAME_SITE=lax
# Keep false only for temporary local testing; enable after configuring a mail provider.
REQUIRE_EMAIL_VERIFICATION=true
# Google Identity Services login. The web and API use the same public Web
# OAuth client ID; no Google client secret is needed for this login flow.
GOOGLE_AUTH_ENABLED=false
GOOGLE_AUTH_CLIENT_ID=
# Enables a persistent JSON database for local evaluation without Supabase.
# Never enable this in production.
LOCAL_DEVELOPMENT_MODE=false
LOCAL_DATA_PATH=.local/nova.json
# Coturn REST credentials. TURN_SECRET stays server-side and the API issues
# time-limited browser credentials. Required for reliable commercial calling.
TURN_URL=
TURN_SECRET=
# Recommended on Render Free: Brevo's HTTPS email API. Free Render services
# block outbound SMTP ports 25, 465, and 587.
MAIL_TRANSPORT=gmail-api
BREVO_API_KEY=
# Recommended on Render Free: sends through Gmail over HTTPS (no SMTP ports).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=novaconnect.verify@gmail.com
# Optional SMTP fallback for hosts/plans that allow outbound SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=NOVA Connect <no-reply@example.com>

# Web (copy these to apps/web/.env.local for local development)
# Optional development-only Vite proxy target. Defaults to http://127.0.0.1:4000.
VITE_DEV_API_TARGET=http://127.0.0.1:4000
VITE_API_URL=http://localhost:4000/api/v1
VITE_SOCKET_URL=http://localhost:4000
VITE_GOOGLE_AUTH_ENABLED=false
VITE_GOOGLE_CLIENT_ID=
VITE_PRODUCT_NAME=NOVA Connect
VITE_PRODUCT_SHORT_NAME=NOVA
VITE_PRODUCT_MARK=N
VITE_LEGAL_NAME=NOVA Connect
VITE_LEGAL_EMAIL=legal@example.com
VITE_SUPPORT_EMAIL=support@example.com
VITE_STATUS_URL=
VITE_TERMS_EFFECTIVE_DATE=2026-07-24
