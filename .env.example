# Shared
NODE_ENV=development

# API
PORT=4000
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:4000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
BCRYPT_ROUNDS=12
COOKIE_SECURE=false
# Use "lax" for the recommended same-origin deployment. Use "none" only when
# web and API are on different sites, and keep COOKIE_SECURE=true.
COOKIE_SAME_SITE=lax
# Enables a persistent JSON database for local evaluation without Supabase.
# Never enable this in production.
LOCAL_DEVELOPMENT_MODE=false
LOCAL_DATA_PATH=.local/nova.json
# Optional Coturn REST credentials. TURN_SECRET stays server-side and the API
# issues time-limited browser credentials. STUN-only defaults are used when omitted.
TURN_URL=
TURN_SECRET=
# Optional SMTP transport for verification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=NOVA Connect <no-reply@example.com>

# Web (copy these to apps/web/.env.local for local development)
# Optional development-only Vite proxy target. Defaults to http://127.0.0.1:4000.
VITE_DEV_API_TARGET=http://127.0.0.1:4000
VITE_API_URL=http://localhost:4000/api/v1
VITE_SOCKET_URL=http://localhost:4000
VITE_GOOGLE_AUTH_ENABLED=false
