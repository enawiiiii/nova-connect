NODE_ENV=development
PRODUCT_NAME=NOVA Connect
PORT=4000
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:4000

# Use Supabase, or enable the local JSON database for evaluation only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
LOCAL_DEVELOPMENT_MODE=true
LOCAL_DATA_PATH=.local/nova.json

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
BCRYPT_ROUNDS=12
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CALL_RECONNECT_GRACE_MS=12000

REQUIRE_EMAIL_VERIFICATION=false
MAIL_TRANSPORT=
MAIL_FROM=NOVA Connect <no-reply@example.com>
BREVO_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=sender@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

GOOGLE_AUTH_ENABLED=false
GOOGLE_AUTH_CLIENT_ID=

TURN_URL=
TURN_SECRET=
TURN_USERNAME=
TURN_CREDENTIAL=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@example.com
